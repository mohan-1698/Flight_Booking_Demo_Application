<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="FlightBook Suite" parallel="tests" thread-count="2">

    <!-- 🔥 Listener for Extent + Screenshot -->
    <listeners>
        <listener class-name="com.srm.hackathon.flightbook.listener.TestListener"/>
    </listeners>

    <!-- 🔥 Each test runs in parallel -->
    <test name="Flight Search Test">
        <classes>
            <class name="com.srm.hackathon.flightbook.tests.FlightSearchTest"/>
        </classes>
    </test>

    <test name="Flight Selection Test">
        <classes>
            <class name="com.srm.hackathon.flightbook.tests.FlightSelectionTest"/>
        </classes>
    </test>

    <test name="Purchase Test">
        <classes>
            <class name="com.srm.hackathon.flightbook.tests.PurchaseTest"/>
        </classes>
    </test>

</suite>